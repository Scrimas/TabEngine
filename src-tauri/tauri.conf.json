{
  "$schema": "https://schema.tauri.app/config/2",

  "productName": "TabEngine",
  "version": "0.1.3",
  "identifier": "dev.tabengine.app",

  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },

  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TabEngine",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "decorations": false,
        "shadow": true
      }
    ],

    "security": {
      "csp": "default-src 'self' tauri: asset: https://ipc.localhost; worker-src 'self' blob:; script-src 'self' 'unsafe-eval' blob:; style-src 'self' 'unsafe-inline'; media-src 'self' blob: data:; img-src 'self' data: blob:; connect-src 'self' ipc: http://ipc.localhost tauri: asset: https://ipc.localhost; font-src 'self' data:"
    }
  },

  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "appimage"],
    "publisher": "Scrimas",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  },

  "plugins": {
    "shell": {
      "open": true
    }
  }
}
